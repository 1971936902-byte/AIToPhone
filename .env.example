HOST=0.0.0.0
PORT=8787
AUTH_TOKEN=change-this-long-random-token

# Use this when you start Codex app-server yourself.
# CODEX_APP_SERVER_URL=ws://127.0.0.1:4500

# If CODEX_APP_SERVER_URL is not set, the gateway will try to launch this.
CODEX_COMMAND=codex.cmd
CODEX_APP_SERVER_PORT=4500

# Remote phone sessions cannot click desktop approval prompts reliably.
# These defaults let Codex edit files, run git write commands, and push when your local credentials allow it.
CODEX_APPROVAL_POLICY=never
CODEX_SANDBOX=danger-full-access
